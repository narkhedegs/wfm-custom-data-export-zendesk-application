{
  "name": "WFM Custom Data Exporter",
  "author": {
    "name": "Jhon Doe",
    "email": "support@zendesk.com",
    "url": "https://www.zendesk.com"
  },
  "defaultLocale": "en",
  "private": true,
  "location": {
    "support": {
      "nav_bar": {
        "url": "http://localhost:3000/",
        "flexible": true
      }
    }
  },
  "version": "1.0.0",
  "frameworkVersion": "2.0",
  "parameters": [
    {
      "name": "max_range_days",
      "type": "number",
      "required": false,
      "default": 31
    },
    {
      "name": "export_timezone",
      "type": "text",
      "required": false,
      "default": "Europe/Warsaw"
    },
    {
      "name": "show_debug_button",
      "type": "checkbox",
      "required": false,
      "default": false
    }
  ]
}
